# ─── Firebase (sole backend) ───────────────────────────────────────────────
# Use values from Firebase Console → Project settings → Your apps → Web app
# VITE_APP_ID must match the web app tied to Firebase Hosting.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=acsusj-web.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=acsusj-web
VITE_FIREBASE_STORAGE_BUCKET=acsusj-web.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Admin portal (client-side gate + Firebase Auth for Firestore) ───────
VITE_ADMIN_USERNAME=nexa_admin
VITE_ADMIN_PASSWORD=
VITE_ADMIN_FIREBASE_EMAIL=admin@nexa2026.internal
VITE_ADMIN_FIREBASE_PASS=
