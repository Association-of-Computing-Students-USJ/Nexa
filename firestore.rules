rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /sponsors/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /projects/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /executive-board/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /executive-board-committee/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /EB_reg_data/{document} {
      allow read: if request.auth != null;
      allow create: if
        request.resource.data.keys().hasOnly([
          'fullName', 'email', 'whatsappNumber', 'department', 'academicYear', 'registrationNumber',
          'linkedinUrl', 'facebookUrl', 'positionPreferences', 'committeePreferences', 'editorialSkills',
          'uploadedWorkUrls', 'tools', 'documentationSkills', 'webDevSkills', 'webDevScreenshotUrls',
          'webDevProjectUrls', 'softSkills', 'softSkillsOther', 'volunteerExperience', 'submittedAt'
        ])
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() >= 2
        && request.resource.data.fullName.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 120
        && request.resource.data.whatsappNumber is string
        && request.resource.data.whatsappNumber.size() <= 20
        && request.resource.data.department is string
        && request.resource.data.academicYear is string
        && request.resource.data.registrationNumber is string
        && request.resource.data.registrationNumber.size() <= 40
        && request.resource.data.linkedinUrl is string
        && request.resource.data.linkedinUrl.size() <= 200
        && request.resource.data.facebookUrl is string
        && request.resource.data.facebookUrl.size() <= 200
        && request.resource.data.positionPreferences is map
        && request.resource.data.committeePreferences is map
        && request.resource.data.editorialSkills is list
        && request.resource.data.uploadedWorkUrls is list
        && request.resource.data.tools is list
        && request.resource.data.documentationSkills is list
        && request.resource.data.webDevSkills is string
        && request.resource.data.webDevSkills.size() <= 2000
        && request.resource.data.webDevScreenshotUrls is list
        && request.resource.data.webDevProjectUrls is string
        && request.resource.data.webDevProjectUrls.size() <= 2000
        && request.resource.data.softSkills is map
        && request.resource.data.softSkillsOther is string
        && request.resource.data.softSkillsOther.size() <= 300
        && request.resource.data.volunteerExperience is map;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // NEXA 2026 event registration
    match /registrations/{docId} {
      // Allow creates where server-side timestamp may be provided via transform
      // (client often uses `serverTimestamp()` which appears as an updateTransform
      // rather than a literal field in request.resource.data.keys()). Exclude
      // `registeredAt` from the required-keys check so timestamp transforms
      // don't cause unintended permission denials.
      allow create: if request.resource.data.keys().hasAll([
          'name', 'email', 'phone', 'whatsapp', 'university', 'year',
          'attended', 'attendedAt', 'mealServed', 'mealServedAt', 'emailStatus'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 120
        && request.resource.data.phone is string
        && request.resource.data.whatsapp is string
        && request.resource.data.university is string
        && request.resource.data.year is string
        && request.resource.data.attended == false
        && request.resource.data.mealServed == false
        && request.resource.data.emailStatus == "pending";
      allow read, delete: if request.auth != null;
      allow update: if request.auth != null;
    }

    // One registration per email — doc id is derived from normalized email
    match /registrationEmails/{emailKey} {
      // Allow creation even when `registeredAt` is supplied as a serverTimestamp()
      // transform by not requiring it in the literal keys list.
      allow create: if !exists(/databases/$(database)/documents/registrationEmails/$(emailKey))
        && request.resource.data.keys().hasAll(['email', 'registrationId'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 120
        && request.resource.data.registrationId is string;
      allow read, update, delete: if request.auth != null;
    }

    // Trigger Email extension
    match /mail/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Nexa Games - Players progress tracking
    match /players/{playerId} {
      allow read, update: if true;
      allow create: if !exists(/databases/$(database)/documents/players/$(playerId))
        && request.resource.data.keys().hasAll(['gameResults', 'totalTimeTaken'])
        && request.resource.data.totalTimeTaken == 0;
      allow delete: if request.auth != null;
    }

    // Nexa Games - Arena Config
    match /arenaConfig/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}